---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/home/HomePage.jsx';

// Get featured/latest project for the featured work section
const projectEntries = await getCollection('projects');
const sortedProjects = projectEntries.sort((a, b) => {
  if (a.data.status === 'active' && b.data.status !== 'active') return -1;
  if (b.data.status === 'active' && a.data.status !== 'active') return 1;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const latestProject = sortedProjects[0] ? {
  slug: sortedProjects[0].slug,
  title: sortedProjects[0].data.title,
  subtitle: sortedProjects[0].data.subtitle,
  status: sortedProjects[0].data.status,
} : null;
---

<BaseLayout title="Greg Toler - Operations & AI Strategy">
  <HomePage
    client:load
    latestProject={latestProject}
  />
</BaseLayout>
