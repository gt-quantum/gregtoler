---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div style="max-width: 800px;">
    <h1 class="animate-on-load" style="font-size: 48px; font-weight: 600; margin-bottom: 24px; letter-spacing: -0.02em;">
      Greg Toler
    </h1>
    <p class="animate-on-load delay-1" style="font-size: 24px; font-weight: 400; margin-bottom: 16px; opacity: 0.8;">
      Developing and optimizing processes that scale.
    </p>
    <p class="animate-on-load delay-2" style="font-size: 16px; line-height: 1.6; opacity: 0.7; max-width: 600px;">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
      incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud
      exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
    </p>
  </div>
</BaseLayout>
