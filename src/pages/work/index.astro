---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkPage from '../../components/work/WorkPage.jsx';

// Get projects and apps from collections
const projectEntries = await getCollection('projects');
const appEntries = await getCollection('apps');

// Transform projects to the format the component expects
const projects = projectEntries.map(entry => ({
  slug: entry.slug,
  title: entry.data.title,
  subtitle: entry.data.subtitle,
  description: entry.data.description,
  status: entry.data.status,
  tags: entry.data.tags,
  date: entry.data.date,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Transform apps to the format the component expects
const apps = appEntries.map(entry => ({
  slug: entry.slug,
  name: entry.data.name,
  type: entry.data.type,
  tagline: entry.data.tagline,
  description: entry.data.description,
  status: entry.data.status,
  tags: entry.data.tags,
  videoUrl: entry.data.videoUrl,
  previewImage: entry.data.previewImage,
  date: entry.data.date,
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<BaseLayout title="Work" description="Projects, apps, and experience by Greg Toler">
  <WorkPage client:load projects={projects} apps={apps} />
</BaseLayout>
