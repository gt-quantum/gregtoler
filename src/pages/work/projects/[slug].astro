---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/prose.css';

export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');
  return projectEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
};

const author = entry.data.author || 'Greg Toler';
const ogImage = entry.data.ogImage || entry.data.coverImage;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <Fragment slot="head">
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    <meta property="article:author" content={author} />
    {entry.data.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>

  <!-- Fixed Back Link -->
  <a href="/work?tab=Projects" class="back-link slide-in-left">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>Back to Work</span>
  </a>

  <article class="project-detail">
    <!-- Header -->
    <header class="header">
      <!-- Meta -->
      <div class="meta fade-in-up">
        <span class="status-dot" data-status={entry.data.status}></span>
        <span class="status-label">{entry.data.status === 'active' ? 'Active' : 'Completed'}</span>
        <span class="meta-dot">·</span>
        <span>{formatDate(entry.data.date)}</span>
      </div>

      <!-- Title -->
      <h1 class="title fade-in-up-delay-1">{entry.data.title}</h1>

      <!-- Subtitle -->
      <p class="subtitle fade-in-up-delay-1">{entry.data.subtitle}</p>

      <!-- Description -->
      <p class="description fade-in-up-delay-2">{entry.data.description}</p>

      <!-- Tags -->
      <div class="tags fade-in-up-delay-3">
        {entry.data.tags.map((tag, i) => (
          <>
            <a href={`/work?tag=${tag}`} class="tag">{tag}</a>
            {i < entry.data.tags.length - 1 && <span class="tag-divider">/</span>}
          </>
        ))}
      </div>
    </header>

    <!-- Cover Image -->
    {entry.data.coverImage && (
      <div class="cover-wrapper scale-fade-in-delay">
        <img
          src={entry.data.coverImage}
          alt={entry.data.title}
          class="cover-image"
        />
      </div>
    )}

    <!-- Metrics -->
    {entry.data.metrics && entry.data.metrics.length > 0 && (
      <div class="metrics-section reveal" data-reveal>
        <h2 class="section-label">Results</h2>
        <div class="metrics-grid">
          {entry.data.metrics.map((metric) => (
            <div class="metric">
              <span class="metric-value">{metric.value}</span>
              <span class="metric-label">{metric.label}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="prose-content reveal" data-reveal>
      <Content />
    </div>

    <!-- Footer -->
    <footer class="footer reveal" data-reveal>
      <div class="author-line">
        <span class="author-label">By</span>
        <span class="author-name">{author}</span>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* Desktop: Fixed back link in left column */
  .back-link {
    position: fixed;
    top: calc(var(--header-height) + var(--content-top-padding));
    left: calc(var(--sidebar-width) + var(--layout-gap));
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
    z-index: 50;
  }

  .back-link:hover {
    color: var(--text);
  }

  .project-detail {
    max-width: 720px;
    margin-left: calc(var(--back-link-column-width) + var(--layout-gap));
  }

  /* Tablet: Reduce back link column */
  @media (max-width: 1024px) {
    .back-link {
      left: calc(var(--sidebar-width) + 16px);
    }

    .project-detail {
      margin-left: calc(var(--back-link-column-width) + 16px);
    }
  }

  /* Tablet/Mobile: Back link flows with content */
  @media (max-width: 900px) {
    .back-link {
      position: relative;
      top: auto;
      left: auto;
      margin-bottom: 24px;
    }

    .project-detail {
      margin-left: 0;
      max-width: 100%;
    }
  }

  /* Mobile: Smaller text */
  @media (max-width: 600px) {
    .title {
      font-size: 1.75rem;
    }

    .description {
      font-size: 1.125rem;
    }

    .tags {
      flex-wrap: wrap;
      gap: 8px;
    }
  }

  .header {
    margin-bottom: 40px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .status-dot[data-status="active"] {
    background: #4ade80;
  }

  .status-label {
    text-transform: capitalize;
  }

  .meta-dot {
    opacity: 0.4;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .description {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 20px;
    font-family: 'Source Serif 4', Georgia, serif;
  }

  .tags {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
  }

  .tag {
    color: var(--text-muted);
    text-decoration: none;
    padding: 2px 6px;
    transition: color 0.2s ease;
  }

  .tag:hover {
    color: var(--text);
  }

  .tag-divider {
    color: var(--text-muted);
    opacity: 0.3;
  }

  .cover-wrapper {
    margin-bottom: 48px;
  }

  .cover-image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
  }

  /* Metrics section */
  .metrics-section {
    margin-bottom: 48px;
    padding: 32px 0;
    border-top: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
  }

  .section-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 32px;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .metric-value {
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text);
    font-family: 'Source Serif 4', Georgia, serif;
  }

  .metric-label {
    font-size: 13px;
    color: var(--text-muted);
  }

  .footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--divider);
  }

  .author-line {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }

  .author-label {
    color: var(--text-muted);
  }

  .author-name {
    color: var(--text);
    font-weight: 500;
  }

  /* CSS variables for theming */
  :global([data-theme="light"]) .project-detail {
    --text: #2C2824;
    --text-muted: #6B6560;
    --bg-tertiary: #E3DED5;
    --divider: #D5D0C9;
  }

  :global([data-theme="dark"]) .project-detail {
    --text: #E3E0DB;
    --text-muted: #A8A49E;
    --bg-tertiary: #2A2622;
    --divider: #3D3935;
  }
</style>

<script>
  // Scroll reveal using Intersection Observer
  const initReveal = () => {
    const reveals = document.querySelectorAll('[data-reveal]');

    if (reveals.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    reveals.forEach(el => observer.observe(el));
  };

  // Run on initial load
  initReveal();

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initReveal);
</script>
