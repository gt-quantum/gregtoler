---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPlayer from '../../components/content/VideoPlayer.jsx';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const resourceEntries = await getCollection('resources');
  return resourceEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
};

const author = entry.data.author || 'Greg Toler';
const ogImage = entry.data.ogImage || entry.data.previewImage;
const hasVideo = !!entry.data.videoUrl;

// Resource type icons map
const typeLabels: Record<string, string> = {
  spreadsheet: 'Spreadsheet',
  pdf: 'PDF',
  tool: 'Tool',
  video: 'Video',
  template: 'Template',
  guide: 'Guide',
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <Fragment slot="head">
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="article" />
  </Fragment>

  <!-- Fixed Back Link -->
  <a href="/resources" class="back-link slide-in-left">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>Back to Resources</span>
  </a>

  <article class="resource-detail">
      <!-- Two-column layout -->
    <div class="header-grid">
      <!-- Left: Info -->
      <div class="header-info">
        <!-- Meta -->
        <div class="meta fade-in-up">
          <span class="meta-icon">
            {entry.data.resourceType === 'spreadsheet' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <line x1="3" y1="9" x2="21" y2="9" />
                <line x1="3" y1="15" x2="21" y2="15" />
                <line x1="9" y1="3" x2="9" y2="21" />
              </svg>
            )}
            {entry.data.resourceType === 'pdf' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
                <polyline points="14,2 14,8 20,8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
              </svg>
            )}
            {entry.data.resourceType === 'template' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <line x1="3" y1="9" x2="21" y2="9" />
                <line x1="9" y1="21" x2="9" y2="9" />
              </svg>
            )}
            {entry.data.resourceType === 'guide' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 19.5A2.5 2.5 0 016.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" />
                <line x1="8" y1="6" x2="16" y2="6" />
                <line x1="8" y1="10" x2="14" y2="10" />
              </svg>
            )}
            {entry.data.resourceType === 'tool' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" />
              </svg>
            )}
            {entry.data.resourceType === 'video' && (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <polygon points="6,4 20,12 6,20" />
              </svg>
            )}
          </span>
          <span class="meta-type">{typeLabels[entry.data.resourceType] || entry.data.resourceType}</span>
          {entry.data.fileFormat && (
            <>
              <span class="meta-dot">·</span>
              <span>{entry.data.fileFormat}</span>
            </>
          )}
        </div>

        <!-- Title -->
        <h1 class="title fade-in-up-delay-1">{entry.data.title}</h1>

        <!-- Description -->
        <p class="description fade-in-up-delay-2">{entry.data.description}</p>

        <!-- Tags -->
        <div class="tags fade-in-up-delay-3">
          {entry.data.tags.map((tag, i) => (
            <>
              <a href={`/resources?tag=${tag}`} class="tag">{tag}</a>
              {i < entry.data.tags.length - 1 && <span class="tag-divider">/</span>}
            </>
          ))}
        </div>

        <!-- Download Button -->
        {entry.data.fileUrl && (
          <div class="download-wrapper fade-in-up-delay-4">
            <a href={entry.data.fileUrl} download class="download-button">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 3v12m0 0l-4-4m4 4l4-4" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2" stroke-linecap="round" />
              </svg>
              <span>Download {entry.data.fileFormat || 'File'}</span>
            </a>
          </div>
        )}
      </div>

      <!-- Right: Preview -->
      <div class="preview-wrapper scale-fade-in-delay">
        <div class="preview-card">
          {entry.data.previewImage ? (
            <img src={entry.data.previewImage} alt={`${entry.data.title} preview`} class="preview-image" />
          ) : (
            <div class="preview-placeholder" />
          )}
          <div class="preview-overlay">
            <span class="preview-label">Preview</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Optional Video Walkthrough -->
    {hasVideo && (
      <div class="video-section reveal" data-reveal>
        <h2 class="section-title">Video Walkthrough</h2>
        <div class="video-wrapper">
          <VideoPlayer
            client:load
            videoUrl={entry.data.videoUrl}
            coverImage={entry.data.previewImage}
            title={`${entry.data.title} walkthrough`}
          />
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="content-wrapper reveal" data-reveal>
      <div class="prose-content">
        <Content />
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer reveal" data-reveal>
      <div class="footer-info">
        <span class="footer-label">Created by</span>
        <span class="footer-value">{author}</span>
        <span class="footer-dot">·</span>
        <span class="footer-label">Updated</span>
        <span class="footer-value">{formatDate(entry.data.updatedDate || entry.data.date)}</span>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* Desktop: Fixed back link in left column */
  .back-link {
    position: fixed;
    top: calc(var(--header-height) + var(--content-top-padding));
    left: calc(var(--sidebar-width) + var(--layout-gap));
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
    z-index: 50;
  }

  .back-link:hover {
    color: var(--text);
  }

  .resource-detail {
    max-width: 1000px;
    margin-left: calc(var(--back-link-column-width) + var(--layout-gap));
  }

  /* Tablet: Reduce back link column */
  @media (max-width: 1024px) {
    .back-link {
      left: calc(var(--sidebar-width) + 16px);
    }

    .resource-detail {
      margin-left: calc(var(--back-link-column-width) + 16px);
    }
  }

  /* Mobile: Back link flows with content */
  @media (max-width: 768px) {
    .back-link {
      position: relative;
      top: auto;
      left: auto;
      margin-bottom: 24px;
    }

    .resource-detail {
      margin-left: 0;
      max-width: 100%;
    }

    .header-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .preview-wrapper {
      order: -1;
    }
  }

  /* Two-column grid */
  .header-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    margin-bottom: 56px;
    align-items: start;
  }

  .header-info {
    display: flex;
    flex-direction: column;
  }

  /* Meta */
  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .meta-icon {
    display: flex;
    align-items: center;
  }

  .meta-type {
    text-transform: capitalize;
  }

  .meta-dot {
    opacity: 0.4;
  }

  /* Title & Description */
  .title {
    font-size: 2rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .description {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 20px;
  }

  /* Tags */
  .tags {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    margin-bottom: 32px;
  }

  .tag {
    color: var(--text-muted);
    text-decoration: none;
    padding: 2px 6px;
    transition: color 0.2s ease;
  }

  .tag:hover {
    color: var(--text);
  }

  .tag-divider {
    color: var(--text-muted);
    opacity: 0.3;
  }

  /* Download Button */
  .download-wrapper {
    margin-top: auto;
  }

  .download-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    font-size: 15px;
    font-weight: 500;
    color: var(--button-text);
    background: var(--button-bg);
    border: none;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .download-button:hover {
    transform: translateY(-2px);
  }

  .download-button:active {
    transform: translateY(0);
  }

  /* Preview Card */
  .preview-wrapper {
    position: sticky;
    top: 24px;
  }

  .preview-card {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .preview-image {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .preview-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    background: var(--bg-tertiary);
  }

  .preview-overlay {
    position: absolute;
    bottom: 12px;
    left: 12px;
  }

  .preview-label {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    background: var(--bg-overlay);
    padding: 4px 8px;
    border-radius: 2px;
  }

  /* Video Section */
  .video-section {
    margin-bottom: 56px;
  }

  .section-title {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .video-wrapper {
    max-width: 720px;
  }

  /* Content */
  .content-wrapper {
    max-width: 720px;
  }

  /* Footer */
  .footer {
    max-width: 720px;
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .footer-info {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    flex-wrap: wrap;
  }

  .footer-label {
    color: var(--text-muted);
  }

  .footer-value {
    color: var(--text);
  }

  .footer-dot {
    color: var(--text-muted);
    opacity: 0.4;
  }

  /* CSS variables for theming */
  :global([data-theme="light"]) .resource-detail {
    --text: #2C2824;
    --text-muted: #6B6560;
    --bg-tertiary: #E3DED5;
    --bg-overlay: rgba(243, 238, 231, 0.9);
    --border: rgba(0, 0, 0, 0.15);
    --button-bg: #2C2824;
    --button-text: #F3EEE7;
  }

  :global([data-theme="dark"]) .resource-detail {
    --text: #E3E0DB;
    --text-muted: #A8A49E;
    --bg-tertiary: #2A2622;
    --bg-overlay: rgba(26, 23, 20, 0.9);
    --border: rgba(255, 255, 255, 0.14);
    --button-bg: #E3E0DB;
    --button-text: #1A1714;
  }
</style>

<script>
  // Scroll reveal using Intersection Observer
  const initReveal = () => {
    const reveals = document.querySelectorAll('[data-reveal]');

    if (reveals.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    reveals.forEach(el => observer.observe(el));
  };

  // Run on initial load
  initReveal();

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initReveal);
</script>
