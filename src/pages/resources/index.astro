---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResourceListing from '../../components/resources/ResourceListing.jsx';

// Get all resource entries
const resourceEntries = await getCollection('resources');

// Transform to the format the component expects
const items = resourceEntries.map(entry => ({
  slug: entry.slug,
  title: entry.data.title,
  description: entry.data.description,
  resourceType: entry.data.resourceType,
  date: entry.data.date,
  tags: entry.data.tags,
  fileFormat: entry.data.fileFormat,
  previewImage: entry.data.previewImage,
}));
---

<BaseLayout title="Resources" description="Downloadable templates, tools, and guides for GTM, operations, and marketing">
  <ResourceListing client:load items={items} />
</BaseLayout>
