---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPlayer from '../../components/content/VideoPlayer.jsx';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const contentEntries = await getCollection('content');
  return contentEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Format date
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  });
};

// Get reading info
const getReadingInfo = () => {
  if (entry.data.contentType === 'video' && entry.data.videoDuration) {
    return entry.data.videoDuration;
  }
  if (entry.data.readingTime) {
    return `${entry.data.readingTime} min read`;
  }
  return null;
};

const hasVideo = entry.data.contentType === 'video' || entry.data.videoUrl;
const readingInfo = getReadingInfo();
const author = entry.data.author || 'Greg Toler';
const ogImage = entry.data.ogImage || entry.data.coverImage;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
>
  <Fragment slot="head">
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={entry.data.date.toISOString()} />
    <meta property="article:author" content={author} />
    {entry.data.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>

    <!-- Fixed Back Link -->
  <a href="/content" class="back-link slide-in-left">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M19 12H5m0 0l6-6m-6 6l6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span>Back to Content</span>
  </a>

  <article class="content-detail">
      <!-- Header -->
    <header class="header">
      <!-- Meta -->
      <div class="meta fade-in-up">
        <span class="meta-icon">
          {entry.data.contentType === 'video' ? (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polygon points="6,4 20,12 6,20" />
            </svg>
          ) : (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="4" y1="6" x2="20" y2="6" stroke-linecap="round" />
              <line x1="4" y1="12" x2="16" y2="12" stroke-linecap="round" />
              <line x1="4" y1="18" x2="12" y2="18" stroke-linecap="round" />
            </svg>
          )}
        </span>
        <span>{entry.data.contentType === 'video' ? 'Video' : 'Article'}</span>
        <span class="meta-dot">·</span>
        <span>{formatDate(entry.data.date)}</span>
        {readingInfo && (
          <>
            <span class="meta-dot">·</span>
            <span>{readingInfo}</span>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="title fade-in-up-delay-1">{entry.data.title}</h1>

      <!-- Description -->
      <p class="description fade-in-up-delay-2">{entry.data.description}</p>

      <!-- Tags -->
      <div class="tags fade-in-up-delay-3">
        {entry.data.tags.map((tag, i) => (
          <>
            <a href={`/content?tag=${tag}`} class="tag">{tag}</a>
            {i < entry.data.tags.length - 1 && <span class="tag-divider">/</span>}
          </>
        ))}
      </div>
    </header>

    <!-- Hero Media -->
    <div class="hero-wrapper scale-fade-in-delay">
      {hasVideo ? (
        <VideoPlayer
          client:load
          videoUrl={entry.data.videoUrl}
          coverImage={entry.data.coverImage || entry.data.videoThumbnail}
          title={entry.data.title}
        />
      ) : entry.data.coverImage ? (
        <img
          src={entry.data.coverImage}
          alt={entry.data.title}
          class="hero-image"
        />
      ) : (
        <div class="hero-placeholder" />
      )}
    </div>

    <!-- Content -->
    <div class="prose-content reveal" data-reveal>
      <Content />
    </div>

    <!-- Footer -->
    <footer class="footer reveal" data-reveal>
      <div class="author-line">
        <span class="author-label">Written by</span>
        <span class="author-name">{author}</span>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  /* Desktop: Fixed back link in left column */
  .back-link {
    position: fixed;
    top: calc(var(--header-height) + var(--content-top-padding));
    left: calc(var(--sidebar-width) + var(--layout-gap));
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
    z-index: 50;
  }

  .back-link:hover {
    color: var(--text);
  }

  .content-detail {
    max-width: 720px;
    margin-left: calc(var(--back-link-column-width) + var(--layout-gap));
  }

  /* Tablet: Reduce back link column */
  @media (max-width: 1024px) {
    .back-link {
      left: calc(var(--sidebar-width) + 16px);
    }

    .content-detail {
      margin-left: calc(var(--back-link-column-width) + 16px);
    }
  }

  /* Mobile: Back link flows with content */
  @media (max-width: 768px) {
    .back-link {
      position: relative;
      top: auto;
      left: auto;
      margin-bottom: 24px;
    }

    .content-detail {
      margin-left: 0;
    }
  }

  .header {
    margin-bottom: 40px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .meta-icon {
    display: flex;
    align-items: center;
  }

  .meta-dot {
    opacity: 0.4;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .description {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .tags {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
  }

  .tag {
    color: var(--text-muted);
    text-decoration: none;
    padding: 2px 6px;
    transition: color 0.2s ease;
  }

  .tag:hover {
    color: var(--text);
  }

  .tag-divider {
    color: var(--text-muted);
    opacity: 0.3;
  }

  .hero-wrapper {
    margin-bottom: 48px;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
  }

  .hero-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background: var(--bg-tertiary);
    border-radius: 4px;
  }

  .footer {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--divider);
  }

  .author-line {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
  }

  .author-label {
    color: var(--text-muted);
  }

  .author-name {
    color: var(--text);
    font-weight: 500;
  }

  /* CSS variables for theming */
  :global([data-theme="light"]) .content-detail {
    --text: #2C2824;
    --text-muted: #6B6560;
    --bg-tertiary: #E3DED5;
    --divider: #D5D0C9;
  }

  :global([data-theme="dark"]) .content-detail {
    --text: #E3E0DB;
    --text-muted: #A8A49E;
    --bg-tertiary: #2A2622;
    --divider: #3D3935;
  }
</style>

<script>
  // Scroll reveal using Intersection Observer
  const initReveal = () => {
    const reveals = document.querySelectorAll('[data-reveal]');

    if (reveals.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    reveals.forEach(el => observer.observe(el));
  };

  // Run on initial load
  initReveal();

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initReveal);
</script>
