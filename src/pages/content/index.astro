---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentListing from '../../components/content/ContentListing.jsx';

// Get all content entries and transform for the component
const contentEntries = await getCollection('content');

const items = contentEntries.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  description: entry.data.description,
  contentType: entry.data.contentType,
  date: entry.data.date,
  tags: entry.data.tags,
  featured: entry.data.featured,
  videoUrl: entry.data.videoUrl,
  videoDuration: entry.data.videoDuration,
  readingTime: entry.data.readingTime,
  coverImage: entry.data.coverImage,
}));
---

<BaseLayout title="Content" description="Articles, videos, and insights on GTM, marketing, sales, and operations">
  <ContentListing client:load items={items} />
</BaseLayout>
